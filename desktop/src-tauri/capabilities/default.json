{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the OpenClaw desktop shell window. Applies to both the tauri:// splash and the http://127.0.0.1:18789 Control UI origin so injected hooks can forward external links via tauri-plugin-opener.",
  "windows": ["main", "login-terminal"],
  "webviews": ["main", "login-terminal"],
  "remote": {
    "urls": [
      "http://127.0.0.1:18789/*",
      "http://localhost:18789/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir",
    "updater:default",
    "process:default",
    "dialog:default"
  ]
}
